# Google OAuth (obter em: console.cloud.google.com → APIs & Services → Credentials)
# Criar "OAuth 2.0 Client ID" tipo "Web Application"
# Adicionar Authorized redirect URI: https://seu-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# NextAuth
# NEXTAUTH_URL: URL completa do app (em dev: http://localhost:3000)
NEXTAUTH_URL=https://seu-app.vercel.app
# NEXTAUTH_SECRET: gerar com: openssl rand -base64 32
NEXTAUTH_SECRET=gere_com_openssl_rand_-base64_32

# (Opcional) URL pública do app
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app/
